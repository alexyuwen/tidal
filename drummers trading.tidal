
-- drummers trading
let
x = 0
-- pats
-- break:13
-- bd: 0, 5, 9, 13
-- hh: 1, 8, 3, 4, 7, 11, 12, 15
-- sd: 2, 6, 10, 14
-- [0|5|9|13]
-- [1|3|4|7|8|11|12|15]
-- [2|6|10|14]
finalPat = slice 16 "14*8" $ loopAt 2 $ s "break:13"
seqPLoopPat = seqPLoop [
  (0, 900, finalPat),
  (996, 1000, gain "0.8 0.5" # s "hc")
  ]
in do
  hush
  setcps 0.5
  setCycle 0
  d1 $ seqPLoopPat

-- 13, 30
once $ s "break:13"
